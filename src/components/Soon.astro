---
import Header from './Header.astro'
---

<div class="container">
  <Header />
  <a href="/" class="text-link">
    <h1 class="text">このページはまだ準備中です。</h1>
  </a>
</div>

<style>
  .container {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .text-link {
    cursor: pointer;
  }
  .text {
    color: var(--text);
    font-size: 1rem;
    letter-spacing: 1.5rem;
  }
</style>
