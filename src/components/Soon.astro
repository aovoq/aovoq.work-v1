---
import Header from './Header.astro'
---

<div class="soon-container">
  <Header />
  <a href="/" class="text-link">
    <h1 class="text">このページはまだ準備中です。</h1>
  </a>
</div>

<style>
  .soon-container {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .text-link {
    cursor: pointer;
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
  }
  .text {
    color: var(--text);
    font-size: 1rem;
    letter-spacing: 1.5rem;
  }

  @media (max-width: 768px) {
    .text {
      font-size: 0.9rem;
      letter-spacing: 0.5rem;
      padding: 0 2rem;
      text-align: center;
    }
  }
</style>
