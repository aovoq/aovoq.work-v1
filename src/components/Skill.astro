---
const { name, index } = Astro.props
const duration = 400 - 15 * index
const delay = 200 + 60 * index
---

<div class="skill-container">
  <div class="skill-icon">
    <slot />
  </div>
  <div class="skill-textbox">
    <div class="skill-text" style={`animation: dropdown ${duration}ms ${delay}ms both var(--ease-out-expo);`}>
      {name}
    </div>
  </div>
</div>

<style>
  .skill-container {
    color: var(--text);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
  }
  .skill-icon {
    height: 2rem;
    font-size: 2rem;
    line-height: 1;
  }
  .skill-textbox {
    padding-top: 0.7rem;
    width: 100%;
    overflow: hidden;
  }
  .skill-text {
    writing-mode: vertical-rl;
    font-size: 1.6rem;
    line-height: 2rem;
  }
  @keyframes dropdown {
    from { transform: translateY(-120%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
</style>
