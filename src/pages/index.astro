---
import Layout from '../layouts/Layout.astro'
import Loading from '../components/Loading.astro'
import Header from '../components/Header.astro'
import BackLoop from '../components/BackLoop.astro'
import IconClose from '../components/icons/IconClose.astro'
import IconAsterisk from '../components/icons/IconAsterisk.astro'
import profileImg from '../assets/aovoq.jpg'

const nameChars = 'Ao Hirata'.split('')
const urlChars = '://aovoq.work'.split('')
const links = ['about', 'works', 'skillset', 'contact']
---

<Layout>
  <div class="home-container">
    <Loading />

    <div id="home-content" style="display:none;">
      <Header home />

      <div class="kanji">碧</div>

      <div class="profile-wrapper">
        <div class="profile-img" style={`background-image: url(${profileImg.src});`}></div>
      </div>

      <h1 class="name">
        {nameChars.map((c, i) => (
          <span
            class={c !== ' ' ? 'fadeIn' : undefined}
            style={c !== ' ' ? `animation-delay: ${0.6 - (0.2 + 0.03 * i)}s;` : undefined}
          >{c}</span>
        ))}
      </h1>

      <span class="url">
        {urlChars.map((c, i) => (
          <span style={`animation-delay: ${50 * (i + 1)}ms;`}>{c}</span>
        ))}
        <span class="url-icon" style={`animation-delay: ${50 * 14}ms;`}>
          <IconAsterisk size="1.5rem" color="hsl(54, 100%, 55%)" />
        </span>
      </span>

      <ul class="links">
        {links.map((item) => (
          <div class="link-wrapper">
            <div class="link-cover"></div>
            <a href={`/${item}`}>
              <IconClose size="1.5rem" />
              <span>{item}</span>
            </a>
          </div>
        ))}
      </ul>

      <ul class="socials">
        <li><a href="https://instagram.com/aovoq">IN</a></li>
        <li class="socials-spacer"></li>
        <li><a href="https://twitter.com/ao_voq">TW</a></li>
        <li class="socials-last"><a href="https://facebook.com/aovoq">FB</a></li>
      </ul>

      <BackLoop />
    </div>
  </div>
</Layout>

<script>
  const lastChar = document.getElementById('loading-last-char')
  if (lastChar) {
    lastChar.addEventListener('animationend', () => {
      const loading = document.getElementById('loading')
      const content = document.getElementById('home-content')
      if (loading) loading.style.display = 'none'
      if (content) {
        content.style.display = ''
        requestAnimationFrame(() => {
          content.classList.add('loaded')
        })
      }
    })
  }
</script>

<style>
  .home-container {
    width: 100%;
    height: 100%;
    overflow: hidden;
    position: relative;
  }

  /* Kanji */
  .kanji {
    position: absolute;
    z-index: 10;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 30rem;
    font-family: serif;
    color: transparent;
    -webkit-text-stroke: 1px var(--text);
    text-stroke: 1px var(--text);
    transform-origin: bottom right;
    animation: kanji-scale-in 600ms 300ms var(--ease-out) both;
  }
  @keyframes kanji-scale-in {
    0% { opacity: 0; transform: translate(-50%, -50%) scale(0.96); }
    100% { opacity: 1; transform: translate(-105%, -70%) scale(1); }
  }

  /* Profile */
  .profile-wrapper {
    position: absolute;
    z-index: 10;
    top: 0; left: 0; right: 0; bottom: 0;
    margin: auto;
    width: 400px;
    height: 400px;
    border-radius: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    background: var(--text);
    animation: profileImg-scale-in 500ms var(--ease-out-back) 0s both;
  }
  @keyframes profileImg-scale-in {
    from { transform: scale(0.9) rotate(-8deg); opacity: 0; }
    to { transform: scale(1) rotate(0deg); opacity: 1; }
  }
  .profile-img {
    width: 99%;
    height: 99%;
    border-radius: 100%;
    filter: grayscale(80%);
    background-size: 245%;
    background-position: 55% 0%;
  }

  /* Name */
  .name {
    position: absolute;
    z-index: 10;
    bottom: 5rem;
    left: 50%;
    transform: translate(-50%);
    font-size: 3rem;
    letter-spacing: 1.5rem;
    font-family: Helvetica Neue, Helvetica, sans-serif;
    color: var(--text);
    overflow: hidden;
  }
  .name .fadeIn {
    display: inline-block;
    transform: translateY(115%);
    animation-duration: 280ms;
    animation-fill-mode: both;
    animation-name: bottom-to-fadeIn;
    animation-timing-function: var(--ease-out);
  }
  @keyframes bottom-to-fadeIn {
    from { transform: translateY(115%); opacity: 0; }
    to { transform: translateY(0%); opacity: 1; }
  }

  /* URL */
  .url {
    position: absolute;
    z-index: 10;
    transform-origin: bottom left;
    transform: rotate(-90deg);
    left: 4rem;
    bottom: 2rem;
    font-size: 1.5rem;
    letter-spacing: 0.5rem;
    font-family: 'Helvetica Neue', sans-serif;
    color: var(--text);
  }
  .url > span {
    display: inline-block;
    animation: url-slide-in 250ms var(--ease-out) both;
  }
  @keyframes url-slide-in {
    from { transform: translateY(-10rem); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  .url-icon {
    position: absolute !important;
    top: 0;
  }
  .url-icon :global(svg) {
    position: absolute;
    top: 0.3rem;
    animation: asterisk-spin 4s 0s linear infinite;
  }
  @keyframes asterisk-spin {
    to { transform: rotate(360deg); }
  }

  /* Links */
  .links {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: absolute;
    z-index: 10;
    top: 50%;
    right: 15%;
    transform: translateY(-50%);
    font-size: 2rem;
    letter-spacing: 0.5rem;
    text-align: left;
    font-family: var(--base-font);
  }
  .links a {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    visibility: hidden;
    transition: transform 160ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .links a:hover {
      transform: translateX(4px);
    }
  }
  .links a:active {
    transform: scale(0.97);
  }
  .link-cover {
    position: absolute;
    width: 180%;
    left: -30%;
    height: 110%;
    background: var(--accent);
    transform: scaleX(0);
  }
  .link-wrapper {
    position: relative;
  }
  .link-wrapper:nth-of-type(1) a { animation: link-visibility 1ms 0.9s forwards; }
  .link-wrapper:nth-of-type(1) .link-cover {
    animation: linksCover-in 200ms 0.7s var(--ease-out) forwards, linksCover-out 180ms 0.9s var(--ease-out) forwards;
  }
  .link-wrapper:nth-of-type(2) a { animation: link-visibility 1ms 1s forwards; }
  .link-wrapper:nth-of-type(2) .link-cover {
    animation: linksCover-in 200ms 0.8s var(--ease-out) forwards, linksCover-out 180ms 1s var(--ease-out) forwards;
  }
  .link-wrapper:nth-of-type(3) a { animation: link-visibility 1ms 1.1s forwards; }
  .link-wrapper:nth-of-type(3) .link-cover {
    animation: linksCover-in 200ms 0.9s var(--ease-out) forwards, linksCover-out 180ms 1.1s var(--ease-out) forwards;
  }
  .link-wrapper:nth-of-type(4) a { animation: link-visibility 1ms 1.2s forwards; }
  .link-wrapper:nth-of-type(4) .link-cover {
    animation: linksCover-in 200ms 1s var(--ease-out) forwards, linksCover-out 180ms 1.2s var(--ease-out) forwards;
  }
  @keyframes link-visibility {
    to { visibility: visible; }
  }
  @keyframes linksCover-in {
    from { transform-origin: left; transform: scaleX(0); }
    to { transform-origin: left; transform: scaleX(1); }
  }
  @keyframes linksCover-out {
    from { transform-origin: right; transform: scaleX(1); }
    to { transform-origin: right; transform: scaleX(0); }
  }

  /* Socials */
  .socials {
    color: var(--text);
    position: absolute;
    z-index: 10;
    bottom: 1.9rem;
    right: 3rem;
    font-size: 1.6rem;
    font-family: Monaco, Courier New, Consolas, monospace;
    font-weight: bold;
    display: flex;
    flex-wrap: wrap;
    flex-direction: row-reverse;
    gap: 0.5rem;
    line-height: 1;
    animation: socials-slide-in 280ms 0s var(--ease-out) both;
  }
  @keyframes socials-slide-in {
    from { transform: translateX(150%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }
  .socials a {
    transition: transform 160ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .socials a:hover {
      transform: scale(1.1);
    }
  }
  .socials a:active {
    transform: scale(0.95);
  }
  .socials-spacer {
    width: 100%;
  }
  .socials-last {
    padding-right: 0.5rem;
  }
</style>
