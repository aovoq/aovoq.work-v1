---

<Layout>
  <div class="works-container">
    <Header />

    <div class="works-scroll">
      <div class="works-scroll-content">
      <div class="works-hero">
        <h1 class="works-title">Works</h1>
        <p class="works-subtitle">Client: baton8</p>
      </div>

      <div class="works-list">
        {projects.map((project) => (
          <article class="project" id={`project-${project.id}`}>
            <div class="project-header">
              <span class="project-id">{project.id}</span>
              <h2 class="project-title">{project.title}</h2>
            </div>

            {project.description && (
              <p class="project-description">{project.description}</p>
            )}

            <div class="project-body">
              <div class="project-visual">
                <img src={project.image} alt={project.title} loading="lazy" />
              </div>

              <div class="project-content">
                <div class="project-links">
                  {project.links.map((link) => (
                    <a href={link.url} target="_blank" rel="noopener noreferrer" class="project-link">
                      {link.label}
                      <span class="link-arrow">↗</span>
                    </a>
                  ))}
                </div>

                {project.answers && (() => {
                  const hasPlace = project.answers.some((a) => a.place !== '')
                  return (
                    <div class="project-answers">
                      <table>
                        <thead>
                          <tr>
                            <th></th>
                            {hasPlace && <th>場所</th>}
                            <th>答え</th>
                            <th></th>
                          </tr>
                        </thead>
                        <tbody>
                          {project.answers.map((a) => (
                            <tr>
                              <td class="answer-q">{a.q}</td>
                              {hasPlace && <td class="answer-place">{a.place}</td>}
                              <td class="answer-text">{a.answer}</td>
                              <td class="answer-link">
                                <a href={a.url} target="_blank" rel="noopener noreferrer">開く ↗</a>
                              </td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  )
                })()}
              </div>
            </div>
          </article>
        ))}
      </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import Lenis from 'lenis'

  const scrollEl = document.querySelector('.works-scroll') as HTMLElement
  if (scrollEl) {
    const contentEl = scrollEl.querySelector('.works-scroll-content') as HTMLElement
    const lenis = new Lenis({
      wrapper: scrollEl,
      content: contentEl,
      lerp: 0.18,
      smoothWheel: true,
    })

    function raf(time: number) {
      lenis.raf(time)
      requestAnimationFrame(raf)
    }
    requestAnimationFrame(raf)
  }
</script>

<style>
  .works-container {
    height: 100%;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .works-scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: thin;
    scrollbar-color: var(--accent) transparent;
  }
  .works-scroll::-webkit-scrollbar {
    width: 3px;
  }
  .works-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .works-scroll::-webkit-scrollbar-thumb {
    background: var(--accent);
  }

  /* Hero */
  .works-hero {
    padding: 8rem 4rem 4rem;
    border-bottom: 1px solid var(--text);
  }
  .works-title {
    color: var(--text);
    font-size: 4.8rem;
    font-weight: bold;
    font-family: var(--base-font);
    letter-spacing: 0.3rem;
    animation: fade-in 500ms var(--ease-out) both;
  }
  .works-subtitle {
    color: var(--text);
    opacity: 0.4;
    font-size: 1.2rem;
    font-family: var(--base-font);
    letter-spacing: 0.2rem;
    margin-top: 0.8rem;
    animation: fade-in 500ms 100ms var(--ease-out) both;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Project list */
  .works-list {
    display: flex;
    flex-direction: column;
  }

  /* Project card */
  .project {
    border-bottom: 1px solid color-mix(in srgb, var(--text) 15%, transparent);
    padding: 4rem;
    animation: project-in 600ms var(--ease-out) both;
    transition: background 300ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .project:hover {
      background: color-mix(in srgb, var(--text) 4%, transparent);
    }
  }
  .project:nth-child(1) { animation-delay: 150ms; }
  .project:nth-child(2) { animation-delay: 200ms; }
  .project:nth-child(3) { animation-delay: 250ms; }
  .project:nth-child(4) { animation-delay: 300ms; }
  .project:nth-child(5) { animation-delay: 350ms; }
  .project:nth-child(6) { animation-delay: 400ms; }
  .project:nth-child(7) { animation-delay: 450ms; }

  @keyframes project-in {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .project-header {
    display: flex;
    align-items: baseline;
    gap: 2rem;
    margin-bottom: 2.4rem;
  }
  .project-id {
    color: var(--accent);
    font-size: 1.2rem;
    font-family: var(--base-font);
    font-weight: bold;
    letter-spacing: 0.1rem;
    flex-shrink: 0;
    transition: transform 300ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .project:hover .project-id {
      transform: translateX(-4px);
    }
  }
  .project-title {
    color: var(--text);
    font-size: 2.2rem;
    font-weight: bold;
    font-family: var(--base-font);
    letter-spacing: 0.05rem;
    line-height: 1.4;
  }

  .project-description {
    color: var(--text);
    opacity: 0.5;
    font-size: 1.1rem;
    font-family: var(--base-font);
    letter-spacing: 0.03rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .project-body {
    display: flex;
    gap: 3.2rem;
  }

  .project-visual {
    flex-shrink: 0;
    width: 240px;
  }
  .project-visual img {
    width: 100%;
    display: block;
    opacity: 0.85;
    transition: opacity 300ms var(--ease-out), transform 300ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .project-visual img:hover {
      opacity: 1;
      transform: scale(1.03);
    }
  }

  .project-content {
    flex: 1;
    min-width: 0;
  }

  /* Links */
  .project-links {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1.2rem;
    font-size: 1.1rem;
    font-family: var(--base-font);
    color: var(--accent);
    border: 1px solid var(--accent);
    letter-spacing: 0.05rem;
    transition: background 200ms var(--ease-out), color 200ms var(--ease-out), transform 200ms var(--ease-out), gap 200ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .project-link:hover {
      background: var(--accent);
      color: var(--bg);
      gap: 0.8rem;
    }
    .project-link:hover .link-arrow {
      transform: translate(1px, -1px);
    }
  }
  .project-link:active {
    transform: scale(0.97);
  }
  .link-arrow {
    font-size: 0.9rem;
    display: inline-block;
    transition: transform 200ms var(--ease-out);
  }

  /* Answer table */
  .project-answers {
    overflow-x: auto;
  }
  .project-answers table {
    width: 100%;
    font-size: 1.1rem;
    font-family: var(--base-font);
    color: var(--text);
  }
  .project-answers thead {
    border-bottom: 1px solid color-mix(in srgb, var(--text) 25%, transparent);
  }
  .project-answers th {
    text-align: left;
    padding: 0.4rem 1rem 0.6rem 0;
    font-size: 1rem;
    opacity: 0.4;
    font-weight: normal;
    white-space: nowrap;
  }
  .project-answers tbody tr {
    transition: background 200ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .project-answers tbody tr:hover {
      background: color-mix(in srgb, var(--text) 6%, transparent);
    }
    .project-answers tbody tr:hover .answer-link a {
      opacity: 1;
      color: var(--accent);
    }
  }
  .project-answers td {
    padding: 0.5rem 1rem 0.5rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--text) 8%, transparent);
    vertical-align: top;
    line-height: 1.5;
  }
  .answer-q {
    color: var(--accent);
    font-weight: bold;
    white-space: nowrap;
    width: 4rem;
  }
  .answer-place {
    opacity: 0.6;
    white-space: nowrap;
  }
  .answer-text {
    word-break: break-all;
  }
  .answer-link {
    white-space: nowrap;
    width: 5rem;
    text-align: right;
  }
  .answer-link a {
    color: var(--text);
    opacity: 0.5;
    font-size: 1rem;
    transition: opacity 200ms var(--ease-out), color 200ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .answer-link a:hover {
      opacity: 1;
      color: var(--accent);
    }
  }
</style>
